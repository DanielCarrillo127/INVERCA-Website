# Copia este archivo como .env y completa los valores reales.

# ==== MongoDB ====
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/coomsocial?retryWrites=true&w=majority
DB_NAME=coomsocial
COLLECTION_NAME=entries

# ==== API ====
# No uses "PORT": Create React App también lo lee y chocaría con :3000.
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# ==== Frontend (Create React App) ====
# Vacío = usa /api del mismo dominio (recomendado en Vercel).
# Solo defínelo si la API corre en otro host.
REACT_APP_API_URL=
